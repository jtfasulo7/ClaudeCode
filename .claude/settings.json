{
  "permissions": {
    "allow": [
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_console_messages",
      "mcp__pipeboard-meta-ads__get_insights",
      "mcp__pipeboard-meta-ads__get_ad_creatives",
      "Bash(curl -s -o /dev/null -w *)",
      "Bash(nslookup *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s 'https://jtfasulo.com/api/telegram-switch?mode=local&secret=fasulo-studio-newsletter' > /dev/null 2>&1 &"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s 'https://jtfasulo.com/api/telegram-switch?mode=cloud&secret=fasulo-studio-newsletter' > /dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
