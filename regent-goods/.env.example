# Regent Goods — environment variables
# Copy to .env.local for local dev. Set the same values in Vercel for production.

# GoHighLevel inbound webhook URL. Inquiry submissions are forwarded here.
# Get this from your GHL workflow → Webhook trigger.
GHL_WEBHOOK_URL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank to disable analytics in this environment.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
