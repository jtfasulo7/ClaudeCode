{
  "buildCommand": "npm install && cd jtfasulo-website && npm install && npm run build",
  "outputDirectory": "jtfasulo-website/dist",
  "installCommand": "echo 'install handled in buildCommand'",
  "rewrites": [{ "source": "/((?!api).*)", "destination": "/index.html" }],
  "crons": [
    {
      "path": "/api/send-newsletter?secret=${CRON_SECRET}",
      "schedule": "30 12 * * 0"
    },
    {
      "path": "/api/telegram-switch?secret=${CRON_SECRET}",
      "schedule": "*/10 * * * *"
    }
  ]
}
